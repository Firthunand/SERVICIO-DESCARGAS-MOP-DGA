[Unit]
Description=Servicio MOP DGA (Xvfb + VNC + Gunicorn)
After=network.target

[Service]
User=datos
Group=datos
WorkingDirectory=/home/datos/SERVICIO-DESCARGAS-MOP-DGA
Environment=PATH=/home/datos/SERVICIO-DESCARGAS-MOP-DGA/env/bin
Environment=LANG=es_CL.UTF-8
Environment=LC_TIME=es_CL.UTF-8

ExecStart=/home/datos/SERVICIO-DESCARGAS-MOP-DGA/scripts/start_servicio_gunicorn.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

